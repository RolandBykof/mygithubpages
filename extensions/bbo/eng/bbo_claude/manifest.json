{
  "manifest_version": 3,
  "name": "BBO Claude",
  "version": "1.0",
  "description": "Adds screen reader support to Bridge Base Online.",
  "author": "Ville Lamminen",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.anthropic.com/"
  ],
  "web_accessible_resources": [
    {
      "resources": ["userguide.html"],
      "matches": ["*://*.bridgebase.com/*"]
    }
  ],
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "*://*.bridgebase.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
