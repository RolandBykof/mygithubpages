{
  "manifest_version": 3,
  "name": "Intercom Toggle – Diarium",
  "version": "1.0",
  "description": "Piilota/näytä Intercom-widget Alt+I -näppäinkomennolla (oma.diarium.fi)",
  "content_scripts": [
    {
      "matches": ["https://oma.diarium.fi/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
