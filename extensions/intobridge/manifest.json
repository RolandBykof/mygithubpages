{
  "manifest_version": 3,
  "name": "IntoBridge Esteettömyyslaajennus",
  "version": "1.0",
  "description": "NVDA-ruudunlukijatuki IntoBridge-bridgepelisivustolle. Ilmoittaa pelitapahtumat automaattisesti ja tarjoaa näppäinkomennot tietojen kyselyyn.",
  "permissions": [],
  "host_permissions": [
    "*://play.intobridge.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://play.intobridge.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "IntoBridge Esteettömyyslaajennus"
  }
}
