{
  "manifest_version": 3,
  "name": "Diarium ruudunlukuapuri",
  "version": "1.0",
  "description": "luo ruudunlukuohjelman käyttöä nopeuttavia elementtejä",
  "content_scripts": [
    {
      "matches": ["https://oma.diarium.fi/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
